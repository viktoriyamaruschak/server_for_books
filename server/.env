# URL LM Studio (не змінюй якщо запускаєш локально)
LM_STUDIO_URL=http://localhost:1234/v1

# Назва моделі завантаженої в LM Studio
# Знайди її у LM Studio → My Models → назва файлу без розширення
# Приклади:
#   LM_STUDIO_MODEL=gemma-3-4b-it
#   LM_STUDIO_MODEL=mistral-7b-instruct-v0.3
#   LM_STUDIO_MODEL=llama-3.2-3b-instruct
LM_STUDIO_MODEL=local-model
